{
  "name": "convex-hydra-poc",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "PoC: Convex + Ory Hydra custom auth using a generated OAuth2 SDK",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": "npx tsx server/auth.ts",
    "build:sdk": "cd sdk && npm install && npm run build"
  },
  "dependencies": {
    "convex": "^1.17.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "express": "^4.21.0",
    "dotenv": "^16.4.0",
    "concurrently": "^9.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vite": "^6.0.0"
  }
}
